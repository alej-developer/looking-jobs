# ==============================================================================
# .env.example — Template for environment variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file itself.
# ==============================================================================

# ─── General ─────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/jobs.db

# ─── Browser Automation (Playwright) ─────────────────────────────────────────
HEADLESS_MODE=true
BROWSER_SLOWMO_MS=0
USER_AGENT=

# ─── Proxy (optional) ────────────────────────────────────────────────────────
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# ─── Resume / Profile ────────────────────────────────────────────────────────
CANDIDATE_FULL_NAME=
CANDIDATE_EMAIL=
CANDIDATE_PHONE=
RESUME_FILE_PATH=

# ─── ATS Portal Credentials (add per-portal sections as needed) ──────────────
# WORKDAY_USERNAME=
# WORKDAY_PASSWORD=
# GREENHOUSE_API_KEY=
# LEVER_API_KEY=
