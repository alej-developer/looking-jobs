.git/
.github/
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.db
*.db-journal
.env
logs/
screenshots/
traces/
test-results/
playwright-report/
playwright-browsers/
browser_state/
storage_state*.json
htmlcov/
.coverage
.pytest_cache/
.ruff_cache/
*.egg-info/
docs/
tests/
benchmark_results/
*.md
!README.md
